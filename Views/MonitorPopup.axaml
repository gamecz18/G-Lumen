<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:G_Lumen.ViewModels"
        xmlns:views="using:G_Lumen.Views"
        xmlns:svc="using:G_Lumen.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="300"
        x:Class="G_Lumen.Views.MonitorPopup"
        x:DataType="vm:MainViewModel"
        Title="G-Lumen"
        Width="340"
        SizeToContent="Height"
        MaxHeight="900"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

    <Window.Styles>
        <Style Selector="Button.icon, ToggleButton.icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock.glyph">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Cascadia Mono,Consolas"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="TextBlock.dim">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
    </Window.Styles>

    <Border CornerRadius="10"
            ClipToBounds="True"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            Padding="0,0,0,8">
        <DockPanel>

            <!-- Header -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="14,10,8,6">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="G-Lumen" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Classes="dim" Text="Monitor brightness" FontSize="10"/>
                </StackPanel>

                <ToggleButton Grid.Column="1" Classes="icon"
                              IsChecked="{Binding ShowDiagnostics, Mode=TwoWay}"
                              ToolTip.Tip="Diagnostics — DDC/CI and DisplayConfig traffic">
                    <TextBlock Classes="glyph" Text="&#xE9D9;"/>
                </ToggleButton>

                <Button Grid.Column="2" Classes="icon"
                        Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Refresh monitors">
                    <TextBlock Classes="glyph" Text="&#xE72C;"/>
                </Button>

                <Button Grid.Column="3" Classes="icon"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip.Tip="Settings">
                    <TextBlock Classes="glyph" Text="&#xE713;"/>
                </Button>
            </Grid>

            <!-- Diagnostics: what goes to the monitors and what comes back.
                 Docked at the bottom → monitors scroll on overflow, the log stays whole. -->
            <StackPanel DockPanel.Dock="Bottom" IsVisible="{Binding ShowDiagnostics}">

                <!-- Handle: drag up/down to resize the log -->
                <Thumb Height="12" Cursor="SizeNorthSouth"
                       DragDelta="OnLogResizeDragDelta"
                       ToolTip.Tip="Drag to resize the log">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Border Background="Transparent">
                                <Border Width="40" Height="4" CornerRadius="2"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <Grid ColumnDefinitions="*,Auto,Auto" Margin="14,0,8,2">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bus traffic" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Classes="dim" FontSize="10"
                                   Text="→ write to monitor · ← read / response"/>
                    </StackPanel>

                    <Button Grid.Column="1" Classes="icon"
                            Command="{Binding ClearTrafficCommand}"
                            ToolTip.Tip="Clear log">
                        <TextBlock Classes="glyph" Text="&#xE74D;" FontSize="13"/>
                    </Button>

                    <Button Grid.Column="2" Classes="icon"
                            Command="{Binding OpenLogFolderCommand}"
                            ToolTip.Tip="Open log folder (g-lumen-*.log, traffic-*.log)">
                        <TextBlock Classes="glyph" Text="&#xE838;" FontSize="13"/>
                    </Button>
                </Grid>

                <!-- Horizontal scrollbar at the bottom: long lines aren't truncated, can be scrolled -->
                <ScrollViewer x:Name="LogScroll" Height="200" Margin="8,4,8,0"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Traffic.Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="svc:TrafficEntry">
                                <StackPanel Orientation="Horizontal"
                                            Margin="6,1"
                                            ToolTip.Tip="{Binding Tooltip}">
                                    <TextBlock Classes="mono dim"
                                               Text="{Binding TimeText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Classes="mono"
                                               Text="{Binding Arrow}"
                                               Margin="6,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                                    <TextBlock Classes="mono dim"
                                               Text="{Binding Channel}"
                                               MinWidth="50"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Classes="mono"
                                               Text="OK"
                                               MinWidth="52"
                                               Margin="6,0"
                                               Foreground="#4CAF50"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding Success}"/>
                                    <TextBlock Classes="mono"
                                               Text="{Binding StatusText}"
                                               MinWidth="52"
                                               Margin="6,0"
                                               Foreground="#E53935"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !Success}"/>
                                    <TextBlock Classes="mono"
                                               Text="{Binding Message}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- Monitors (fill the rest; scroll on overflow) -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MonitorViewModel">
                                <views:MonitorSlider/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No DDC/CI monitors found."
                               Margin="14,8"
                               TextWrapping="Wrap"
                               Classes="dim"
                               IsVisible="{Binding !Monitors.Count}"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
