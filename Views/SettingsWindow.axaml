<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:G_Lumen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="520"
        x:Class="G_Lumen.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="G-Lumen — Settings"
        Width="440"
        Height="520"
        MinWidth="380"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Window.Styles>
        <Style Selector="TextBlock.glyph">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
        </Style>
        <Style Selector="TextBlock.dim">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
        <Style Selector="Button.move">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="20,18,20,12">
            <TextBlock Text="Monitors" FontSize="18" FontWeight="Bold"/>
            <TextBlock Classes="dim"
                       Text="Rename monitors and use the arrows to change their order in the popup."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Button footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Cancel"
                        MinWidth="90"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Save"
                        MinWidth="90"
                        Classes="accent"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>

        <!-- Monitor cards -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Monitors}" Margin="20,0,20,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MonitorNameEntry">
                        <Border Margin="0,0,0,10"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <!-- Position badge -->
                                <Border Width="38" Height="38"
                                        CornerRadius="8"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="0">
                                        <TextBlock Classes="glyph"
                                                   Text="&#xE7F4;"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Position}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,12,0" Spacing="3">
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Classes="dim"
                                               Text="{Binding Monitor.GdiDeviceName}"
                                               FontFamily="Cascadia Mono,Consolas"
                                               FontSize="10"/>
                                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                                             Margin="0,3,0,0"
                                             PlaceholderText="{Binding Description}"/>
                                </StackPanel>

                                <!-- Reorder arrows -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Spacing="2"
                                            Width="30">
                                    <Button Classes="move"
                                            Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).MoveUpCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Move up">
                                        <TextBlock Classes="glyph" Text="&#xE70E;" FontSize="11"/>
                                    </Button>
                                    <Button Classes="move"
                                            Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).MoveDownCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Move down">
                                        <TextBlock Classes="glyph" Text="&#xE70D;" FontSize="11"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
