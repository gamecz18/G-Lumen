<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:G_Lumen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="320"
        x:Class="G_Lumen.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="G-Lumen — Nastavení"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Text="Názvy monitorů"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Vlastní názvy se zobrazí v popupu místo systémového popisu."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   Margin="0,0,0,12"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="Zrušit" Command="{Binding CancelCommand}"/>
            <Button Content="Uložit" Command="{Binding SaveCommand}"
                    Classes="accent"/>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Monitors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MonitorNameEntry">
                        <StackPanel Margin="0,0,0,12" Spacing="2">
                            <TextBlock Text="{Binding Description}"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       FontSize="12"/>
                            <TextBox Text="{Binding Name, Mode=TwoWay}"
                                     PlaceholderText="{Binding Description}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
