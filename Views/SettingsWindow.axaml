<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:G_Lumen.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="520"
        x:Class="G_Lumen.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="G-Lumen — Settings"
        Width="440"
        Height="520"
        MinWidth="380"
        MinHeight="340"
        WindowStartupLocation="CenterScreen"
        CanResize="True">

    <Window.Styles>
        <Style Selector="TextBlock.glyph">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
        </Style>
        <Style Selector="TextBlock.dim">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="20,18,20,12">
            <TextBlock Text="Monitor names" FontSize="18" FontWeight="Bold"/>
            <TextBlock Classes="dim"
                       Text="Custom names are shown in the popup instead of the system description."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Button footer -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Cancel"
                        MinWidth="90"
                        IsCancel="True"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Save"
                        MinWidth="90"
                        Classes="accent"
                        IsDefault="True"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>

        <!-- Monitor cards -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Monitors}" Margin="20,0,20,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MonitorNameEntry">
                        <Border Margin="0,0,0,10"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                            <Grid ColumnDefinitions="Auto,*">

                                <Border Width="38" Height="38"
                                        CornerRadius="8"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                    <TextBlock Classes="glyph"
                                               Text="&#xE7F4;"
                                               FontSize="17"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="3">
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Classes="dim"
                                               Text="{Binding Monitor.GdiDeviceName}"
                                               FontFamily="Cascadia Mono,Consolas"
                                               FontSize="10"/>
                                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                                             Margin="0,3,0,0"
                                             PlaceholderText="{Binding Description}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
